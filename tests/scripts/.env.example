# smoke-test.sh configuration for terraform-aws-n8n.
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your API key.

# ── Terraform directory ────────────────────────────────────────────────────────
# Path to the Terraform directory to read state from.
# Defaults to the current working directory, so running the script from inside
# examples/complete (or your own root configuration) just works without setting
# this. Override if running the script from a different location.
# TERRAFORM_DIR=/path/to/examples/complete

# ── Auto-detected from Terraform (override here if needed) ────────────────────
# These are read automatically from `terraform output` when TERRAFORM_DIR has
# a terraform.tfstate. Only set them here to explicitly override.

# Base URL of your n8n deployment (no trailing slash).
# N8N_URL=https://n8n.example.com

# Kubernetes namespace n8n is deployed into.
# N8N_NAMESPACE=n8n

# ── Required for API and workflow execution tests ─────────────────────────────
# n8n API key — create one in n8n: Settings > API > Create API Key
N8N_API_KEY=your-api-key-here

# ── Optional load-scaling test ────────────────────────────────────────────────
# Set to "true" to fire CPU-burning workflow executions and confirm KEDA
# (or the worker HPA, if configured) scales workers up.
# LOAD_TEST=false

# Number of webhook executions to fire during the load test (default: 100).
# LOAD_REQUESTS=100

# How long each worker job burns CPU in seconds (default: 10).
# Increase to 60+ if workers aren't saturating before the autoscaler reacts.
# LOAD_JOB_DURATION_SECS=10

# Seconds to wait for the autoscaler to react after load is applied (default: 180).
# KEDA / HPA have built-in stabilization windows — scaling won't appear instantly.
# SCALE_WAIT_SECS=180

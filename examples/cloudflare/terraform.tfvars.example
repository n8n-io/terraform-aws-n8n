# Copy this file to terraform.tfvars and fill in your values.

# Fully-qualified domain for n8n. Must be a subdomain managed in your
# Cloudflare zone (e.g. n8n.example.com if your zone is example.com).
n8n_domain = "n8n.example.com"

# Cloudflare zone ID for the domain above. Find it on the Overview page
# of your zone in the Cloudflare dashboard (right-hand sidebar).
cloudflare_zone_id = "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4"

# Cloudflare API token with Zone:DNS:Edit permission.
# Create one at https://dash.cloudflare.com/profile/api-tokens.
# You can also export CLOUDFLARE_API_TOKEN instead of setting this.
cloudflare_api_token = "your-cloudflare-api-token-here"

# n8n Enterprise license activation key. Get one at https://n8n.io/pricing.
n8n_license_key = "your-enterprise-license-key-here"

# AWS region. Change if you're deploying outside us-east-1.
# aws_region = "eu-west-1"

# EKS cluster name. Keep to 14 characters or fewer — ElastiCache cluster IDs
# derived from this name are capped at 20 chars, and '-redis' consumes 6.
# cluster_name = "n8n-cluster"

# Extra AWS tags applied to every resource this example creates.
# tags = {
#   Environment = "production"
#   Owner       = "platform-team"
# }

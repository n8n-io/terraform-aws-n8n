# Copy this file to terraform.tfvars and fill in your values.
# n8n_license_key is required — all other variables have sensible defaults.
# n8n_domain, aws_region, and cluster_name live in the prerequisites workspace.

# Your n8n Enterprise license key. Get one at https://n8n.io/pricing
n8n_license_key = "your-enterprise-license-key-here"

# Additional tags applied to every AWS resource this workspace creates
# (EKS, RDS, Redis, S3, IAM roles…). Merged on top of the built-in ManagedBy/Project tags.
# tags = {
#   CostCenter  = "engineering"
#   Environment = "production"
#   Owner       = "platform-team"
# }

# Kubernetes namespace.
# namespace = "n8n"

# Worker nodes. Multi-main requires t3.xlarge (4 vCPU) minimum — the 6 n8n pods request
# ~3,600m CPU at minimum replicas, leaving t3.medium nodes with insufficient headroom for HPA.
# node_instance_type = "t3.xlarge"
# node_desired       = 3
# node_min           = 3
# node_max           = 6

# RDS instance class. db.t3.small (~$25/month) is fine for most teams.
# Upgrade to db.t3.medium for high query volume.
# db_instance_class    = "db.t3.small"
# db_multi_az          = true      # set false to halve RDS cost in non-prod environments
# db_allocated_storage = 50

# ElastiCache node type.
# redis_node_type = "cache.t3.medium"

# n8n Helm chart version to deploy.
# n8n_chart_version = "1.4.0"

# Timezone for n8n's scheduler.
# n8n_timezone = "UTC"

# CPU and memory requests and limits for n8n pods.
# Increase if workflows are CPU- or memory-intensive or if you observe throttling/OOMKills.
# n8n_main_cpu_request       = "1000m"
# n8n_main_cpu_limit         = "2000m"
# n8n_main_memory_request    = "2Gi"
# n8n_main_memory_limit      = "4Gi"
# n8n_worker_cpu_request     = "500m"
# n8n_worker_cpu_limit       = "1000m"
# n8n_worker_memory_request  = "1Gi"
# n8n_worker_memory_limit    = "2Gi"
# n8n_webhook_cpu_request    = "300m"
# n8n_webhook_cpu_limit      = "800m"
# n8n_webhook_memory_request = "512Mi"
# n8n_webhook_memory_limit   = "1Gi"

# Worker concurrency: jobs each worker pod handles simultaneously.
# n8n_worker_concurrency = 10

# Execution timeouts (seconds). timeoutMax is the ceiling users can configure themselves.
# n8n_execution_timeout     = 7200
# n8n_execution_timeout_max = 7200

# Maximum concurrent production executions (-1 = unlimited).
# n8n_execution_concurrency_limit = 100

# Execution data pruning. maxAge is in hours (336 = 14 days).
# n8n_pruning_max_age   = 336
# n8n_pruning_max_count = 10000

# Graceful shutdown timing.
# MINIMUMS — do not lower these values. Lowering terminationGracePeriodSeconds risks
# killing pods before in-flight executions complete; lowering prestop_sleep drops
# requests that haven't been drained from the load balancer yet.
# n8n_termination_grace_period = 60
# n8n_prestop_sleep            = 10

# Task runners: isolated sidecar containers for JavaScript and Python code execution.
# Enabled by default — a runner sidecar is added to each main and worker pod, scaling 1:1.
# Set to false to disable.
# n8n_task_runners_enabled = true

# Resource requests and limits for the task runner sidecar.
# n8n_task_runner_cpu_request    = "200m"
# n8n_task_runner_cpu_limit      = "1"
# n8n_task_runner_memory_request = "512Mi"
# n8n_task_runner_memory_limit   = "1Gi"

# Seconds of inactivity before the runner shuts down (0 = never).
# n8n_task_runner_auto_shutdown_timeout = 15

# Enable the native Python runner (beta). Required for Python workflow nodes.
# n8n_task_runner_python_enabled = true

# Seconds n8n waits for a task runner to accept a Code node task before timing out.
# Increase if Code nodes fail with "task request timed out" under high concurrency.
# n8n_runners_task_request_timeout = 300

# ─── Additional environment variables ────────────────────────────────────────
# Not all n8n environment variables are exposed as Terraform variables in this template.
# For a complete list of available configuration options, see:
# https://docs.n8n.io/hosting/configuration/environment-variables/
